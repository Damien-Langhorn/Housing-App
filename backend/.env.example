# ===================================
# 🔒 HOUSING APP BACKEND ENVIRONMENT
# ===================================

# ✅ Database Configuration
MONGO_URI=""
# MONGO_URI=""

# ✅ Clerk Authentication
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_WEBHOOK_SIGNING_SECRET=whsec_your_webhook_secret_here

# ✅ Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here

# ✅ Server Configuration
PORT=5000
NODE_ENV=development
# NODE_ENV=production

# ✅ Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
# FRONTEND_URL=https://your-domain.com

# ✅ Security Settings
SESSION_SECRET=your_super_secret_session_key_here_minimum_32_characters
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters

# ✅ File Upload Configuration
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# ===================================
# 🚨 SECURITY NOTES:
# ===================================
# 1. NEVER commit this file to version control
# 2. Use strong, unique secrets in production
# 3. Rotate secrets regularly
# 4. Use environment-specific values
# 5. Enable SSL/TLS in production
# ===================================
